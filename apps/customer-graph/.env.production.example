# ============================================
# Auth-SSO Customer Graph - Vercel 生产环境变量
# ============================================
# 在 Vercel Dashboard > Settings > Environment Variables 中配置

# 运行环境
NODE_ENV=production

# 应用配置
NEXT_PUBLIC_APP_URL=https://your-customer-graph-domain.vercel.app

# ============================================
# IdP OAuth 配置
# ============================================
NEXT_PUBLIC_IDP_URL=https://your-idp-domain.vercel.app
NEXT_PUBLIC_CLIENT_ID=customer-graph
IDP_CLIENT_SECRET=your-customer-graph-client-secret

# OAuth 回调 URL
NEXT_PUBLIC_REDIRECT_URI=https://your-customer-graph-domain.vercel.app/api/auth/callback

# ============================================
# Redis 配置 (Upstash - Vercel KV Storage)
# ============================================
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=xxx
KV_REST_API_READ_ONLY_TOKEN=xxx
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ============================================
# Session 配置
# ============================================
SESSION_IDLE_TIMEOUT_MS=1800000
SESSION_ABSOLUTE_TIMEOUT_MS=604800000
TOKEN_REFRESH_THRESHOLD_MS=300000