# ============================================
# Auth-SSO Customer Graph - 本地开发环境变量
# ============================================

# 运行环境
NODE_ENV=development

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:4003

# ============================================
# IdP OAuth 配置
# ============================================
NEXT_PUBLIC_IDP_URL=http://localhost:4001
NEXT_PUBLIC_CLIENT_ID=customer-graph
IDP_CLIENT_SECRET=your-customer-graph-client-secret

# OAuth 回调 URL
NEXT_PUBLIC_REDIRECT_URI=http://localhost:4003/api/auth/callback

# ============================================
# Redis 配置 (本地 Docker Redis)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Session 配置
# ============================================
SESSION_IDLE_TIMEOUT_MS=1800000
SESSION_ABSOLUTE_TIMEOUT_MS=604800000
TOKEN_REFRESH_THRESHOLD_MS=300000

# ============================================
# 外部 API 配置（客户关系数据）
# ============================================
CUSTOMER_API_URL=https://api.example.com
CUSTOMER_API_KEY=your-api-key