# ============================================
# Auth-SSO IdP - 本地开发环境变量
# ============================================
# 1. 复制此文件为 .env.local
# 2. 替换下面的占位符为实际值

# 运行环境标识 (本地开发)
NODE_ENV=development

# 数据库配置 (Docker PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_sso_idp

# Redis 配置 (Docker Redis)
REDIS_URL=redis://localhost:6379

# Better Auth 配置
# 生成密钥: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-min-32-chars-long
BETTER_AUTH_URL=http://localhost:4001

# JWT 配置
# 生成密钥: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_ISSUER=auth-sso
