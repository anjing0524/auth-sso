# ==============================================================================
# Auth-SSO Identity Provider (IdP) - 生产部署环境变量模板 (.env.prod)
# ==============================================================================
# 注意：在生产环境/Docker Compose 部署时，复制此文件为 .env.prod 并将其中的敏感信息进行替换。
# ==============================================================================

# 1. 核心运行环境
# ------------------------------------------------------------------------------
NODE_ENV=production

# 2. 数据库配置 (连接至 Docker Compose 内部的 postgres 容器)
# ------------------------------------------------------------------------------
# 数据库用户名，默认 postgres
POSTGRES_USER=postgres
# 【必须修改】数据库连接密码，请设置为一个极为强壮的随机字符串
POSTGRES_PASSWORD=your_highly_secure_db_password
# 数据库名称，与 docker-compose.prod.yml 中保持一致
POSTGRES_DB=auth_sso
# 生产环境连接串，主机名使用 Docker 网络内部解析的 postgres，端口使用 5432
DATABASE_URL=postgresql://postgres:your_highly_secure_db_password@postgres:5432/auth_sso

# 3. Redis 缓存与 Session 存储配置 (连接至 Docker Compose 内部的 redis 容器)
# ------------------------------------------------------------------------------
# 【必须修改】Redis 连接密码，与 docker-compose.prod.yml 中 requirepass 保持一致
REDIS_PASSWORD=your_highly_secure_redis_password
# 生产环境连接串，主机名使用 Docker 网络内部解析的 redis，端口使用 6379
REDIS_URL=redis://:your_highly_secure_redis_password@redis:6379

# 4. Better Auth 认证套件核心配置
# ------------------------------------------------------------------------------
# 【必须修改】客户端及 Better Auth 的主入口 URL，互联网部署时【必须】使用 https:// 开头的真实互联网域名
# 示例：https://idp.yourdomain.com
BETTER_AUTH_URL=https://idp.yourdomain.com

# 【必须修改】Better Auth 加密密钥，用于加密 Session 等数据。
# 生产环境【必须】使用强随机密钥，请在终端执行以下命令生成并替换：
# 命令：openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_must_be_generated_min_32_chars

# 5. OIDC / JWT 安全令牌签名配置
# ------------------------------------------------------------------------------
# 【必须修改】用于签名 OIDC ID Token 及 Access Token 的密钥。
# 生产环境【必须】使用强随机密钥，请在终端执行以下命令生成并替换：
# 命令：openssl rand -base64 32
JWT_SECRET=your_jwt_secret_must_be_generated_min_32_chars
# JWT 签发者标识，用于校验 Token 来源
JWT_ISSUER=auth-sso

# 6. Portal 与子应用安全客户端密钥 (与 Portal 中的配置必须一致)
# ------------------------------------------------------------------------------
# 【必须修改】管理门户 Portal 接入认证中心的 OAuth 2.0 密钥。
# 请在终端执行以下命令生成强随机十六进制字符串并替换：
# 命令：openssl rand -hex 32
PORTAL_CLIENT_SECRET=your_portal_client_secret_must_be_generated

# Demo 示例应用的接入密钥 (若不需要可保留默认或置空)
DEMO_APP_CLIENT_SECRET=your_demo_app_client_secret_must_be_generated
