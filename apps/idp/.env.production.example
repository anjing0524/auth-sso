# ============================================
# Auth-SSO IdP - Vercel 生产环境变量
# ============================================
# 在 Vercel Dashboard > Settings > Environment Variables 中配置

# 运行环境
NODE_ENV=production

# 应用配置
NEXT_PUBLIC_APP_URL=https://your-idp-domain.vercel.app

# ============================================
# 数据库配置 (Neon PostgreSQL - Vercel Storage)
# ============================================
# 使用 Vercel Postgres Storage 提供的连接字符串
DATABASE_URL=postgresql://neondb_owner:npg_xxx@ep-xxx-pooler.c-5.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_URL=postgresql://neondb_owner:npg_xxx@ep-xxx-pooler.c-5.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:npg_xxx@ep-xxx.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# ============================================
# Redis 配置 (Upstash - Vercel KV Storage)
# ============================================
# 使用 Vercel KV Storage 提供的连接信息
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=xxx
KV_REST_API_READ_ONLY_TOKEN=xxx
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ============================================
# Better Auth 配置
# ============================================
# 生成密钥: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-chars
BETTER_AUTH_URL=https://your-idp-domain.vercel.app

# JWT 配置
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_ISSUER=auth-sso

# ============================================
# Client Secrets (用于 Portal, Demo App 和 Customer Graph)
# ============================================
# 生成: openssl rand -hex 32
PORTAL_CLIENT_SECRET=your-portal-client-secret
PORTAL_REDIRECT_URL=https://your-portal-domain.vercel.app/api/auth/callback

DEMO_APP_CLIENT_SECRET=your-demo-app-client-secret
DEMO_APP_REDIRECT_URL=https://your-demo-domain.vercel.app/auth/callback

CUSTOMER_GRAPH_CLIENT_SECRET=your-customer-graph-client-secret
CUSTOMER_GRAPH_REDIRECT_URL=https://your-customer-graph-domain.vercel.app/api/auth/callback
