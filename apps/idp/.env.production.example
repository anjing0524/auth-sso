# ============================================
# Auth-SSO IdP - Vercel 生产环境变量
# ============================================
# 在 Vercel Dashboard > Settings > Environment Variables 中配置

# 运行环境
NODE_ENV=production

# 应用配置
NEXT_PUBLIC_APP_URL=https://your-idp-domain.vercel.app

# 数据库配置 (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Redis 配置 (Upstash)
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your-upstash-redis-token

# Better Auth 配置
# 生成密钥: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-chars
BETTER_AUTH_URL=https://your-idp-domain.vercel.app

# JWT 配置
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_ISSUER=auth-sso

# Client Secrets (用于 Portal 和 Demo App)
# 生成: openssl rand -hex 32
PORTAL_CLIENT_SECRET=your-portal-client-secret
PORTAL_REDIRECT_URL=https://your-portal-domain.vercel.app/api/auth/callback

DEMO_APP_CLIENT_SECRET=your-demo-app-client-secret
DEMO_APP_REDIRECT_URL=https://your-demo-domain.vercel.app/auth/callback
