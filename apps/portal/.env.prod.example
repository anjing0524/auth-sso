# ==============================================================================
# Auth-SSO Portal (管理门户) - 生产部署环境变量模板 (.env.prod)
# ==============================================================================
# 注意：在生产环境/Docker Compose 部署时，复制此文件为 .env.prod
#       并将其中的敏感信息进行替换。
# ==============================================================================

# 1. 核心运行环境
# ------------------------------------------------------------------------------
NODE_ENV=production

# 2. 应用基础 URL（Internet 可访问的完整域名）
# ------------------------------------------------------------------------------
# 【必须修改】管理门户 Portal 的外网访问根地址，互联网部署时【必须】使用 https://
# 示例：https://portal.yourdomain.com
BETTER_AUTH_URL=https://portal.yourdomain.com
NEXT_PUBLIC_APP_URL=https://portal.yourdomain.com

# 【必须修改】用于对会话和 Token 签名的密钥
# 生产环境【必须】使用强随机密钥，在终端执行以下命令生成：
# 命令：openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_must_be_generated_min_32_chars

# 3. 数据库配置 (连接至 Docker Compose 内部的 postgres 容器)
# ------------------------------------------------------------------------------
# 数据库用户名，默认 postgres
POSTGRES_USER=postgres
# 【必须修改】数据库连接密码
POSTGRES_PASSWORD=your_highly_secure_db_password
# 数据库名称，与 docker-compose.prod.yml 中保持一致
POSTGRES_DB=auth_sso
# 生产环境连接串，主机名使用 Docker 网络内部解析的 postgres，端口使用 5432
DATABASE_URL=postgresql://postgres:your_highly_secure_db_password@postgres:5432/auth_sso

# 4. Redis 缓存与 Session 存储配置 (连接至 Docker Compose 内部的 redis 容器)
# ------------------------------------------------------------------------------
# 【必须修改】Redis 连接密码，与 docker-compose.prod.yml 中 requirepass 保持一致
REDIS_PASSWORD=your_highly_secure_redis_password
# 生产环境连接串，主机名使用 Docker 网络内部解析 of redis，端口使用 6379
REDIS_URL=redis://:your_highly_secure_redis_password@redis:6379

# 5. OIDC Provider 配置（通常与 BETTER_AUTH_URL 相同，无需单独设置）
# ------------------------------------------------------------------------------
# PORTAL_ISSUER=https://portal.yourdomain.com
# PORTAL_JWKS_URI=https://portal.yourdomain.com/api/auth/.well-known/jwks

# 6. OAuth 客户端配置（Portal 自身的 OAuth 凭证）
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLIENT_ID=portal
# 【必须修改】与 IdP 配置中的 PORTAL_CLIENT_SECRET 保持一致的 OAuth 2.0 密钥
IDP_CLIENT_SECRET=your_portal_client_secret_must_be_generated
# 回调地址
NEXT_PUBLIC_REDIRECT_URI=https://portal.yourdomain.com/api/auth/callback

# 7. CORS 信任域（【必须修改】生产环境必须显式配置）
# ------------------------------------------------------------------------------
# 逗号分隔的完整 URL，包含 Portal + 所有接入的 SSO 客户端域名
TRUSTED_ORIGINS=https://portal.yourdomain.com,https://demo.yourdomain.com

# 8. Portal Session 安全加密配置
# ------------------------------------------------------------------------------
# 【必须修改】用于对 Portal 自身 Session 进行签名和加密。
# 命令：openssl rand -base64 32
SESSION_SECRET=your_session_secret_must_be_generated_min_32_chars
