# ============================================
# Auth-SSO Portal — 生产环境模板（Docker Compose 部署）
# ============================================
# 使用：cp .env.prod.example .env.prod
# ============================================

NODE_ENV=production
LOG_LEVEL=info

NEXT_PUBLIC_APP_URL=https://portal.yourdomain.com
NEXT_PUBLIC_APP_NAME=Auth-SSO Portal

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_highly_secure_db_password
POSTGRES_DB=auth_sso

DATABASE_URL=postgresql://postgres:your_highly_secure_db_password@postgres:5432/auth_sso

REDIS_PASSWORD=your_highly_secure_redis_password
REDIS_URL=redis://:your_highly_secure_redis_password@redis:6379

PORTAL_CLIENT_SECRET=your_portal_client_secret_must_be_generated
