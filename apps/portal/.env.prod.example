# ==============================================================================
# Auth-SSO Portal (管理门户) - 生产部署环境变量模板 (.env.prod)
# ==============================================================================
# 注意：在生产环境/Docker Compose 部署时，复制此文件为 .env.prod 并将其中的敏感信息进行替换。
# ==============================================================================

# 1. 核心运行环境
# ------------------------------------------------------------------------------
NODE_ENV=production

# 2. 数据库配置 (连接至 Docker Compose 内部的 postgres 容器)
# ------------------------------------------------------------------------------
# 数据库用户名，默认 postgres
POSTGRES_USER=postgres
# 【必须修改】数据库连接密码，请与 apps/idp/.env.prod 中设置的数据库密码保持完全一致
POSTGRES_PASSWORD=your_highly_secure_db_password
# 数据库名称，与 docker-compose.prod.yml 中保持一致
POSTGRES_DB=auth_sso
# 生产环境连接串，主机名使用 Docker 网络内部解析的 postgres，端口使用 5432
DATABASE_URL=postgresql://postgres:your_highly_secure_db_password@postgres:5432/auth_sso

# 3. Redis 缓存与 Session 存储配置 (连接至 Docker Compose 内部的 redis 容器)
# ------------------------------------------------------------------------------
# 【必须修改】Redis 连接密码，与 docker-compose.prod.yml 中 requirepass 保持一致
REDIS_PASSWORD=your_highly_secure_redis_password
# 生产环境连接串，主机名使用 Docker 网络内部解析 of redis，端口使用 6379
REDIS_URL=redis://:your_highly_secure_redis_password@redis:6379

# 4. Identity Provider (IdP) 整合通信配置
# ------------------------------------------------------------------------------
# 【必须修改】IdP 身份认证中心的外网访问根地址，互联网部署时【必须】使用 https:// 开头的真实互联网域名
# 示例：https://idp.yourdomain.com
NEXT_PUBLIC_IDP_URL=https://idp.yourdomain.com

# 【必须修改】与 apps/idp/.env.prod 中的 PORTAL_CLIENT_SECRET 保持完全一致的 OAuth 2.0 密钥
IDP_CLIENT_SECRET=your_portal_client_secret_must_be_generated

# 5. Portal 门户自身访问配置
# ------------------------------------------------------------------------------
# 【必须修改】管理门户 Portal 的外网访问根地址，互联网部署时【必须】使用 https:// 开头的真实互联网域名
# 示例：https://portal.yourdomain.com
NEXT_PUBLIC_APP_URL=https://portal.yourdomain.com

# 6. Portal Session 安全加密配置
# ------------------------------------------------------------------------------
# 【必须修改】用于对 Portal 自身 Session 进行签名和加密。
# 生产环境【必须】使用强随机密钥，请在终端执行以下命令生成并替换：
# 命令：openssl rand -base64 32
SESSION_SECRET=your_session_secret_must_be_generated_min_32_chars
