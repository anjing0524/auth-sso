# ============================================
# Auth-SSO Portal - Vercel 生产环境变量
# ============================================
# 在 Vercel Dashboard > Settings > Environment Variables 中配置

# 运行环境
NODE_ENV=production

# 应用配置
NEXT_PUBLIC_APP_URL=https://your-portal-domain.vercel.app

# ============================================
# 数据库配置 (Neon PostgreSQL - Vercel Storage)
# ============================================
# 使用 Vercel Postgres Storage 提供的连接字符串
DATABASE_URL=postgresql://neondb_owner:npg_xxx@ep-xxx-pooler.c-5.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_URL=postgresql://neondb_owner:npg_xxx@ep-xxx-pooler.c-5.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:npg_xxx@ep-xxx.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# ============================================
# Redis 配置 (Upstash - Vercel KV Storage)
# ============================================
# 使用 Vercel KV Storage 提供的连接信息
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=xxx
KV_REST_API_READ_ONLY_TOKEN=xxx
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ============================================
# IdP 连接配置
# ============================================
NEXT_PUBLIC_IDP_URL=https://your-idp-domain.vercel.app
IDP_CLIENT_SECRET=与 IdP 中配置的 PORTAL_CLIENT_SECRET 相同

# Session 配置
SESSION_SECRET=your-session-secret-min-32-chars
