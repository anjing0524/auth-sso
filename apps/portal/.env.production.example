# ============================================
# Auth-SSO Portal - 生产环境变量（Vercel / 云部署）
# ============================================

# 运行环境
NODE_ENV=production

# ------------------------------------------------------------------
# 应用基础 URL（必须设置）
# ------------------------------------------------------------------
# Better Auth 服务端 URL
BETTER_AUTH_URL=https://your-portal-domain.example.com
# 客户端公开 URL
NEXT_PUBLIC_APP_URL=https://your-portal-domain.example.com

# Better Auth 密钥（必须使用强随机密钥）
# 生成命令: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-chars

# ------------------------------------------------------------------
# 数据库配置 (PostgreSQL)
# ------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@your-db-host:5432/auth_sso_portal?sslmode=require
POSTGRES_URL=postgresql://user:password@your-db-host:5432/auth_sso_portal?sslmode=require

# ------------------------------------------------------------------
# Redis 配置
# ------------------------------------------------------------------
REDIS_URL=redis://your-redis-host:6379

# ------------------------------------------------------------------
# OIDC Provider 配置（通常与 BETTER_AUTH_URL 相同，无需单独设置）
# ------------------------------------------------------------------
# PORTAL_ISSUER=https://your-portal-domain.example.com
# PORTAL_JWKS_URI=https://your-portal-domain.example.com/api/auth/.well-known/jwks

# ------------------------------------------------------------------
# OAuth 客户端配置
# ------------------------------------------------------------------
NEXT_PUBLIC_CLIENT_ID=portal
IDP_CLIENT_SECRET=与 IdP 中配置的 PORTAL_CLIENT_SECRET 相同
NEXT_PUBLIC_REDIRECT_URI=https://your-portal-domain.example.com/api/auth/callback

# ------------------------------------------------------------------
# CORS / 信任域（必须设置！逗号分隔）
# 包含 Portal 自身域名和所有接入的 SSO 客户端域名
# ------------------------------------------------------------------
TRUSTED_ORIGINS=https://your-portal-domain.example.com,https://your-demo-app.example.com

# Session 密钥
SESSION_SECRET=your-session-secret-min-32-chars
