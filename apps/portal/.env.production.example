# ============================================
# Auth-SSO Portal — 生产环境模板（Vercel / 云部署）
# ============================================
# 必填：DATABASE_URL, TRUSTED_ORIGINS（生产必须显式设置）
# ============================================

NODE_ENV=production
LOG_LEVEL=info

# 必须替换为实际域名
NEXT_PUBLIC_APP_URL=https://your-portal-domain.example.com

# PostgreSQL（必须替换）
DATABASE_URL=postgresql://user:password@your-db-host:5432/auth_sso_portal?sslmode=require

REDIS_URL=redis://your-redis-host:6379

# OIDC Provider（通常无需单独设置）
# PORTAL_ISSUER=https://your-portal-domain.example.com
# PORTAL_JWKS_URI=https://your-portal-domain.example.com/api/auth/.well-known/jwks

# Portal OAuth Client（必须替换 PORTAL_CLIENT_SECRET）
NEXT_PUBLIC_CLIENT_ID=portal
PORTAL_CLIENT_ID=portal
PORTAL_CLIENT_SECRET=your-portal-client-secret

# CORS 信任域（必须替换！逗号分隔，包含 Portal + 所有 SSO 客户端域名）
TRUSTED_ORIGINS=https://your-portal-domain.example.com,https://your-demo-app.example.com
