# ============================================
# Auth-SSO Portal - 生产环境变量
# ============================================

# 运行环境
NODE_ENV=production

# 应用配置
NEXT_PUBLIC_APP_URL=https://your-portal-domain.example.com

# ============================================
# 数据库配置 (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@your-db-host:5432/auth_sso_portal?sslmode=require
POSTGRES_URL=postgresql://user:password@your-db-host:5432/auth_sso_portal?sslmode=require

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://your-redis-host:6379

# ============================================
# IdP 连接配置
# ============================================
NEXT_PUBLIC_IDP_URL=https://your-idp-domain.example.com
IDP_CLIENT_SECRET=与 IdP 中配置的 PORTAL_CLIENT_SECRET 相同

# Session 配置
SESSION_SECRET=your-session-secret-min-32-chars
