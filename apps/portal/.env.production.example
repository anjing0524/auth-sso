# ============================================
# Auth-SSO Portal — 生产环境模板（Vercel / 云部署）
# ============================================
# 必填：DATABASE_URL, PORTAL_CLIENT_SECRET
# ============================================

NODE_ENV=production
LOG_LEVEL=info

# 必须替换为实际域名
NEXT_PUBLIC_APP_URL=https://your-portal-domain.example.com
NEXT_PUBLIC_APP_NAME=Auth-SSO Portal

# PostgreSQL（必须替换）
DATABASE_URL=postgresql://user:password@your-db-host:5432/auth_sso_portal?sslmode=require

REDIS_URL=redis://your-redis-host:6379

# OIDC Issuer（默认 = NEXT_PUBLIC_APP_URL，通常无需设置）
# PORTAL_ISSUER=https://your-portal-domain.example.com

# Portal OAuth Client Secret（必须替换）
PORTAL_CLIENT_SECRET=your-portal-client-secret
