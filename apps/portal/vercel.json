{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm install && pnpm --filter @auth-sso/portal build",
  "devCommand": "pnpm dev",
  "installCommand": "cd ../.. && pnpm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["hkg1"],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://portal.auth-sso.vercel.app",
    "NEXT_PUBLIC_IDP_URL": "https://idp.auth-sso.vercel.app",
    "NEXT_PUBLIC_CLIENT_ID": "portal"
  }
}