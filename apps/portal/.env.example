# ============================================
# Auth-SSO Portal — 本地开发模板
# ============================================
# 使用：cp .env.example .env.local
# ============================================

NODE_ENV=development
LOG_LEVEL=info

NEXT_PUBLIC_APP_URL=http://localhost:4100
NEXT_PUBLIC_APP_NAME=Auth-SSO Portal

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_sso_portal
REDIS_URL=redis://localhost:6379

PORTAL_CLIENT_SECRET=portal-secret

# 安全策略可选覆盖（不设置则使用默认值）
# PASSWORD_HISTORY_MAX=5          # 密码历史保留上限（最近N次不可重用）
# SIGNATURE_TIMESTAMP_WINDOW_SEC=60  # HMAC 签名时间戳容忍窗口（秒）
# BRUTE_FORCE_MAX_ATTEMPTS=5      # 暴力破解锁定阈值（失败次数）
# BRUTE_FORCE_WINDOW_MINUTES=15   # 暴力破解锁定窗口（分钟）
# GATEWAY_SHARED_SECRET=          # Gateway-Portal HMAC 信任路径共享密钥（生产必须设置）
# COOKIE_SECURE=true              # 强制 Cookie Secure 标志（HTTPS 环境）
# PORTAL_JWKS_URI=                # 覆盖 JWKS 端点 URL（默认自动拼接）
