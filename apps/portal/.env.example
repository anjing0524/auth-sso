# ============================================
# Auth-SSO Portal - 本地开发环境变量
# ============================================
# 1. 复制此文件为 .env.local
# 2. 替换下面的占位符为实际值

# 运行环境标识 (本地开发)
NODE_ENV=development

# ------------------------------------------------------------------
# 应用基础 URL（Portal 自身访问地址）
# 本地默认端口 4100（与 gateway 对齐）
# ------------------------------------------------------------------
# Better Auth 使用的服务端 URL（优先级最高）
BETTER_AUTH_URL=http://localhost:4100
# 客户端侧使用的公开 URL
NEXT_PUBLIC_APP_URL=http://localhost:4100

# Better Auth 密钥（生成命令: openssl rand -base64 32）
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-chars

# ------------------------------------------------------------------
# 数据库配置 (Docker PostgreSQL)
# ------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_sso_portal

# ------------------------------------------------------------------
# Redis 配置 (Docker Redis)
# ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------
# Session / JWT 密钥
# 生成命令: openssl rand -base64 32
# ------------------------------------------------------------------
SESSION_SECRET=your-session-secret-min-32-chars-long

# ------------------------------------------------------------------
# OIDC Provider 配置
# ------------------------------------------------------------------
# Issuer 标识（默认与 BETTER_AUTH_URL / NEXT_PUBLIC_APP_URL 相同）
# PORTAL_ISSUER=http://localhost:4100
# JWKS 端点（默认自动拼接 /api/auth/.well-known/jwks）
# PORTAL_JWKS_URI=http://localhost:4100/api/auth/.well-known/jwks

# ------------------------------------------------------------------
# OAuth 客户端配置（Portal 作为 OIDC Provider 时自身使用的客户端凭证）
# ------------------------------------------------------------------
NEXT_PUBLIC_CLIENT_ID=portal
IDP_CLIENT_SECRET=portal-secret
NEXT_PUBLIC_REDIRECT_URI=http://localhost:4100/api/auth/callback

# ------------------------------------------------------------------
# CORS / 信任域（生产环境必须设置，本地开发自动覆盖常见端口）
# 格式：逗号分隔的完整 URL
# ------------------------------------------------------------------
# TRUSTED_ORIGINS=https://portal.yourdomain.com,https://demo.yourdomain.com

# ------------------------------------------------------------------
# 限流开关（可选）
# ------------------------------------------------------------------
# DISABLE_RATE_LIMIT=true
