# ============================================
# Auth-SSO Portal — 本地开发模板
# ============================================
# 使用：cp .env.example .env.local
# 必填：DATABASE_URL
# ============================================

NODE_ENV=development
LOG_LEVEL=info

NEXT_PUBLIC_APP_URL=http://localhost:4100
NEXT_PUBLIC_APP_NAME=Auth-SSO Portal

# 必填：PostgreSQL 连接串
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_sso_portal

# 默认 localhost:6379
REDIS_URL=redis://localhost:6379

# OIDC Issuer（默认 = NEXT_PUBLIC_APP_URL，通常无需设置）
# PORTAL_ISSUER=http://localhost:4100

# Portal OAuth Client Secret（scripts/seed.ts 回退为 portal-secret）
PORTAL_CLIENT_SECRET=portal-secret
