# ============================================
# Auth-SSO Portal — 本地开发环境变量模板
# ============================================
# 使用：cp .env.example .env.local → 编辑 .env.local
# 校验：packages/config/src/env.ts (Zod schema)
# 必填：DATABASE_URL, BETTER_AUTH_SECRET
# ============================================

# ── 运行环境 ──────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── 应用 URL ──────────────────────────────
BETTER_AUTH_URL=http://localhost:4100
NEXT_PUBLIC_APP_URL=http://localhost:4100

# ── 密钥（必填 *，≥32字符） ───────────────
# 生成命令：openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-chars

# ── 数据库（必填 *）── Docker PostgreSQL ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_sso_portal

# ── Redis（默认 localhost:6379）───────────
REDIS_URL=redis://localhost:6379

# ── OIDC Provider ─────────────────────────
# 默认与 BETTER_AUTH_URL 相同，通常无需单独设置
# PORTAL_ISSUER=http://localhost:4100
# PORTAL_JWKS_URI=http://localhost:4100/api/auth/.well-known/jwks

# ── Portal 自身 OAuth Client ──────────────
# Portal 作为 OIDC Provider 时的客户端凭证
NEXT_PUBLIC_CLIENT_ID=portal
PORTAL_CLIENT_ID=portal
PORTAL_CLIENT_SECRET=portal-secret

# ── CORS ──────────────────────────────────
# 本地开发自动追加常见 localhost 端口，通常无需设置
# TRUSTED_ORIGINS=https://portal.yourdomain.com

# ── Session TTL ───────────────────────────
SESSION_MAX_AGE_SEC=604800
SESSION_IDLE_TIMEOUT_SEC=86400
