# ============================================
# Auth-SSO — 统一环境变量模板
# ============================================
# 使用：cp .env.example .env.local 然后按需修改
# ============================================

# --- 运行环境 ---
NODE_ENV=development
LOG_LEVEL=info

# --- 应用基础配置 ---
NEXT_PUBLIC_APP_URL=http://localhost:4100
NEXT_PUBLIC_APP_NAME=Auth-SSO Portal
# Portal 进程监听端口（Docker 内为 4000）
PORT=4100

# --- 数据库 ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_sso_portal

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- OAuth 2.1 / OIDC ---
# Portal 自身作为 OIDC Provider 的内置客户端密钥
PORTAL_CLIENT_SECRET=portal-secret
# OIDC Issuer（不设置则自动推导为 NEXT_PUBLIC_APP_URL）
# PORTAL_ISSUER=https://sso.example.com
# 内部回调 URL（Gateway → Portal 令牌交换用，生产环境必须设置）
# PORTAL_INTERNAL_URL=http://portal:4100

# --- Gateway 信任路径 HMAC ---
# Gateway 上游转发时用此密钥对 (timestamp + userId + jti) 计算 HMAC-SHA256 签名。
# 生产环境必须配置；本地开发可留空（跳过 HMAC 校验）。
GATEWAY_SHARED_SECRET=

# --- CORS ---
# 生产环境用逗号分隔的受信任来源域列表
# TRUSTED_ORIGINS=https://app1.example.com,https://app2.example.com
