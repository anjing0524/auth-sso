{
  "name": "auth-sso",
  "version": "1.1.1.1",
  "private": true,
  "description": "小企业统一门户 + SSO + 权限中心",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:portal": "pnpm --filter @auth-sso/portal dev",
    "dev:demo": "pnpm --filter @auth-sso/demo-app dev",
    "build": "pnpm -r build",
    "build:portal": "pnpm --filter @auth-sso/portal build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @auth-sso/portal db:generate",
    "db:migrate": "pnpm --filter @auth-sso/portal db:migrate",
    "db:push": "pnpm --filter @auth-sso/portal db:push",
    "db:studio": "pnpm --filter @auth-sso/portal db:studio",
    "db:seed": "pnpm --filter @auth-sso/portal db:seed",
    "infra:up": "docker compose up -d",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "vitest run --project @auth-sso/portal",
    "test:components": "vitest run --project @auth-sso/portal 'apps/portal/__tests__/components/app-sidebar.test.tsx' 'apps/portal/__tests__/components/permission-guard.test.tsx'",
    "test:e2e": "playwright test",
    "test:e2e:release": "playwright test tests/e2e/docker-release.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:report": "node tests/traceability/generate-report.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "tsx": "^4.22.4",
    "wait-on": "^8.0.0",
    "vitest": "^4.1.9"
  }
}
