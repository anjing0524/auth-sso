{
  "name": "auth-sso",
  "version": "1.0.0.1",
  "private": true,
  "description": "小企业统一门户 + SSO + 权限中心",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:portal": "pnpm --filter @auth-sso/portal dev",
    "build": "pnpm -r build",
    "build:portal": "pnpm --filter @auth-sso/portal build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @auth-sso/portal db:generate",
    "db:migrate": "pnpm --filter @auth-sso/portal db:migrate",
    "db:push": "pnpm --filter @auth-sso/portal db:push",
    "db:studio": "pnpm --filter @auth-sso/portal db:studio",
    "db:seed": "pnpm --filter @auth-sso/portal db:seed",
    "infra:up": "docker compose up -d",
    "setup:env": "echo '请手动复制 .env.example 文件到 .env.local 并配置'",
    "start:services": "cd tests && ./start-services.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "vitest run --project @auth-sso/portal",
    "test:portal": "vitest run --project @auth-sso/portal",
    "test:components": "vitest run --project @auth-sso/portal '**/__tests__/components/**'",
    "test:integration:oauth": "tsx tests/integration/oauth-flow.test.ts",
    "test:integration:m3": "tsx tests/integration/m3-verification.test.ts",
    "test:integration": "tsx tests/integration/oauth-flow.test.ts && tsx tests/integration/m3-verification.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:report": "node tests/traceability/generate-report.mjs",
    "clean": "pnpm -r clean",
    "clean:all": "pnpm -r clean && rm -rf node_modules .pnpm-store"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "server-only": "^0.0.1",
    "vitest": "^4.1.8"
  }
}
