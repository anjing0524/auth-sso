{
  "name": "auth-sso",
  "version": "1.0.0",
  "private": true,
  "description": "小企业统一门户 + SSO + 权限中心",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:portal": "pnpm --filter @auth-sso/portal dev",
    "dev:idp": "pnpm --filter @auth-sso/idp dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @auth-sso/idp db:generate",
    "db:migrate": "pnpm --filter @auth-sso/idp db:migrate",
    "db:push": "pnpm --filter @auth-sso/idp db:push",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.12.4"
}